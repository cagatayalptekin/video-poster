DATABASE_URL="file:./dev.db"

# Admin credentials (change in production)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme"

# JWT secret for session tokens (generate a random string)
JWT_SECRET="change-this-to-a-random-secret-in-production"

# Upload settings
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=500

# Instagram Playwright Publisher
# Set INSTAGRAM_PROVIDER=playwright to use real browser automation (default: mock)
INSTAGRAM_PROVIDER=mock
INSTAGRAM_LOGIN_USERNAME=
INSTAGRAM_LOGIN_PASSWORD=
INSTAGRAM_2FA_CODE=
INSTAGRAM_HEADLESS=true

# TikTok Content Posting API (Official)
# Set TIKTOK_PROVIDER=official to use real TikTok API (default: mock)
TIKTOK_PROVIDER=mock
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback
TIKTOK_API_BASE_URL=https://open.tiktokapis.com
TIKTOK_REQUEST_TIMEOUT_MS=60000

# YouTube Data API v3 (Official)
# Set YOUTUBE_PROVIDER=official to use real YouTube API (default: mock)
YOUTUBE_PROVIDER=mock
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CATEGORY_ID=22
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback
YOUTUBE_API_BASE_URL=https://www.googleapis.com
YOUTUBE_UPLOAD_PRIVACY_STATUS=private
YOUTUBE_REQUEST_TIMEOUT_MS=60000
